app:
  name: "AMELI App Template"
  slug: "ameli-app"
  environment: "dev"
  timezone: "America/Santiago"

api:
  host: "127.0.0.1"
  port: 18080
  require_token: false
  token_env: "AMELI_APP_API_TOKEN"

auth:
  enabled: true
  # Leave session_cookie_name empty (or omit it) to let the template
  # apply the ASVS V3.4.4 ``__Host-`` prefix policy automatically
  # outside dev. Set it explicitly only if your deploy needs a legacy
  # name (reverse proxy strips ``__Host-``, bookmarks pinned to a
  # specific name, etc.).
  session_cookie_name: ""
  session_cookie_secure: false
  session_max_age_seconds: 43200
  # When true, every authenticated request renews the cookie expiry, so
  # session_max_age_seconds behaves like an inactivity timeout. When
  # false, the cookie age is a hard cap from creation.
  session_idle_renewal: true
  # When true, the cookie is destroyed when the browser closes. When
  # false, it persists until session_max_age_seconds elapses.
  session_expire_at_browser_close: false
  profile_uploads_dir: "data/uploads/dev"

dashboard:
  enabled: true
  title: "AMELI App Template"
  public: true
  port: 18081

docs:
  enabled: true
  redoc_enabled: true

worker:
  enabled: true
  interval_seconds: 300
  heartbeat_max_age_seconds: 900

notifier:
  enabled: false
  interval_seconds: 30

database:
  # PostgreSQL is the official database standard for real deployments.
  # SQLite is supported only as a local fallback when DATABASE_URL is empty.
  url_env: "DATABASE_URL"
  pool_pre_ping: true
  connect_timeout_seconds: 5

paths:
  data_dir: "data"
  log_dir: "logs"
  backup_dir: "backups"

features:
  admin: true
  audit_log: true
  maintenance: true

email:
  # Outgoing email for transactional flows (password reset, etc).
  # Backend: "console" prints to stdout/journalctl (great for dev),
  # "smtp" delivers via a real server, "file" writes .eml files to data_dir.
  backend: "console"
  host: ""
  port: 587
  use_tls: true
  use_ssl: false
  username_env: "AMELI_APP_EMAIL_USERNAME"
  # Password resolution precedence: AMELI_APP_EMAIL_PASSWORD env, then
  # password_file (or AMELI_APP_EMAIL_PASSWORD_FILE env), then the env var
  # named by password_env. Use password_file for prod to keep the secret out
  # of the env file and the systemd unit logs.
  password_env: "AMELI_APP_EMAIL_PASSWORD"
  # password_file: "/etc/ameli-app/secrets/email_default.password"
  from_address: "noreply@ameli-template.local"
  password_reset_timeout_seconds: 3600
  url_base_env: "AMELI_APP_URL_BASE"
