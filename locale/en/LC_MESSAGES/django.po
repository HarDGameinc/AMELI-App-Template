msgid "Demasiados intentos desde esta direccion. Espera unos segundos."
msgstr "Too many attempts from this address. Wait a few seconds."

msgid ""
"Cuenta bloqueada temporalmente por demasiados intentos fallidos. Espera unos "
"minutos o usa la recuperacion de clave."
msgstr ""
"Account temporarily locked after too many failed attempts. Wait a few "
"minutes or use password recovery."

msgid "Sesion cerrada."
msgstr "Signed out."

msgid "Perfil actualizado."
msgstr "Profile updated."

msgid "No se pudo guardar el perfil."
msgstr "Could not save profile."

msgid "Imagen de perfil actualizada."
msgstr "Profile picture updated."

msgid "Imagen de perfil eliminada."
msgstr "Profile picture removed."

msgid "No se pudo actualizar la contrasena."
msgstr "Could not update password."
