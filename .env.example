# Runtime
APP_ENV=dev
APP_LOG_LEVEL=INFO
APP_CONFIG=config/app.yaml.example
APP_SYSTEMD_PROFILE=api-worker-maintenance

# API / Django web
AMELI_APP_HOST=127.0.0.1
# API_PORT is the ONLY port bound under the default profile
# (api-worker-maintenance): one Django ASGI process serves both the HTML
# dashboard and the JSON API, and Caddy reverse-proxies to it. Convention:
# prod defaults to 80XX, dev to 18XX (overridable; use high ports on a
# host that already runs other apps). See docs/OPERATIONS.md "Architecture".
AMELI_APP_API_PORT=18080
# WEB_PORT is a RESERVED extension seam, NOT dead config: it is bound only
# when APP_SYSTEMD_PROFILE includes "web", which runs ameli-app-web.service
# (today an alias of the same ASGI app — see ameli_app/web.py). It is the
# plug point a child app or a future frontend split swaps behind without
# renaming the unit. Left at the default under api-only profiles.
AMELI_APP_WEB_PORT=18081
AMELI_APP_NOTIFIER_INTERVAL=30
AMELI_APP_REQUIRE_TOKEN=false
AMELI_APP_API_TOKEN=change-me
AMELI_APP_AUTH_ENABLED=true
AMELI_APP_DOCS_ENABLED=true
AMELI_APP_REDOC_ENABLED=true
AMELI_APP_ADMIN_ENABLED=true
AMELI_APP_SESSION_COOKIE_NAME=ameli_app_session
AMELI_APP_SESSION_COOKIE_SECURE=false
AMELI_APP_SESSION_MAX_AGE_SECONDS=43200
# The three crypto keys below (SECRET_KEY, AUDIT_HMAC_KEY,
# MFA_ENCRYPTION_KEY) are AUTO-GENERATED by scripts/install.sh on the
# first install (idempotent — never overwrites) and land in
# /etc/<slug>/app.env, not here. Left commented so the operator sees they
# exist. In dev without an env file, config.py falls back to bundled
# insecure defaults which the fail-closed guards refuse to boot outside
# APP_ENV=dev. See docs/DECISIONS.md #10.
# AMELI_APP_DJANGO_SECRET_KEY=
# AMELI_APP_AUDIT_HMAC_KEY=
# AMELI_APP_MFA_ENCRYPTION_KEY=
AMELI_APP_DJANGO_DEBUG=true

# Local fallback only. Leave empty in real installs that use PostgreSQL.
AMELI_APP_SQLITE_PATH=

# Optional first-install bootstrap for superadmin.
# Example:
# AMELI_APP_BOOTSTRAP_ADMIN_USER=admin
# AMELI_APP_BOOTSTRAP_ADMIN_PASSWORD=change-this-now

# Official database standard: PostgreSQL
# Example:
# DATABASE_URL=postgresql+psycopg://ameli_app:secret@127.0.0.1:5432/ameli_app
DATABASE_URL=
